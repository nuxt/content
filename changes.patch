+++ b/src/utils/build-encryption.ts
@@ -0,0 +1,93 @@
+// Build-time encryption utilities (Node context)
+// Produces base64(JSON envelope) from base64(gzip(JSON dump))
+import { subtle, getRandomValues } from 'uncrypto'
+
+const te = new TextEncoder()
+
+function b64ToBytes(b64: string): Uint8Array {
+  return Buffer.from(b64, 'base64')
+}
+function bytesToB64(arr: Uint8Array): string {
+  return Buffer.from(arr).toString('base64')
+}
+function toArrayBuffer(u8: Uint8Array): ArrayBuffer {
+  const out = new ArrayBuffer(u8.byteLength)
+  new Uint8Array(out).set(u8)
+  return out
+}
+
+async function deriveContentKeyRaw(
+  masterKeyB64: string,
+  checksum: string,
+  collection: string,
+): Promise<Uint8Array> {
+  const master = b64ToBytes(masterKeyB64)
+  const hkdfKey = await subtle.importKey(
+    'raw',
+    toArrayBuffer(master),
+    { name: 'HKDF' },
+    false,
+    ['deriveKey'],
+  )
+  const derived = await subtle.deriveKey(
+    { name: 'HKDF', hash: 'SHA-256', salt: te.encode(checksum || ''), info: te.encode(`content:${collection}`) },
+    hkdfKey,
+    { name: 'AES-GCM', length: 256 },
+    true,
+    ['encrypt'],
+  )
+  const raw = new Uint8Array(await subtle.exportKey('raw', derived))
+  return raw
+}
+
+export async function encryptGzBase64Envelope(
+  gzBase64: string,
+  masterKeyB64: string,
+  checksum: string,
+  collection: string,
+): Promise<string> {
+  const keyRaw = await deriveContentKeyRaw(masterKeyB64, checksum, collection)
+  const key = await subtle.importKey(
+    'raw',
+    toArrayBuffer(keyRaw),
+    { name: 'AES-GCM' },
+    false,
+    ['encrypt'],
+  )
+  const iv = getRandomValues(new Uint8Array(12))
+  const gzBytes = b64ToBytes(gzBase64)
+  const ct = new Uint8Array(
+    await subtle.encrypt({ name: 'AES-GCM', iv: toArrayBuffer(iv) }, key, toArrayBuffer(gzBytes)),
+  )
+
+  const envelope = {
+    v: 1,
+    alg: 'A256GCM',
+    kid: `v1:${collection}:${checksum}`,
+    iv: bytesToB64(iv),
+    ciphertext: bytesToB64(ct),
+  }
+  return Buffer.from(JSON.stringify(envelope), 'utf8').toString('base64')
+}
